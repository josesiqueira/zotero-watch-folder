# Dependencies
node_modules/

# Build output
dist/
*.xpi

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
.claude/
.cursor/
.copilot/
notes/
Notes/
Zotero API/
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Local test fixtures — large PDFs used by MCP runbooks and ad-hoc live
# tests. Each developer keeps their own set; we don't want them in git.
test_pdfs/

# Private / historical content: legacy design notes, MCP runbooks,
# test PDFs, stale XPI artifacts. Kept locally for the maintainer's
# reference but not shipped with the public repo. See
# .private/README.md for what's in there.
.private/

# Per-machine MCP server config (Claude Code's @introfini/mcp-server-zotero-dev
# wiring). The server itself is npx-installed; this file just records which
# command runs locally, so it varies per environment.
.mcp.json

# update.json is generated by `npm run package` but committed so Zotero
# clients can reach it from the main branch via manifest.json's update_url.
